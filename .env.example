# RetroTV Environment Variables
# Copy this file to .env and fill in your values.
# On macOS Docker Desktop, use host.docker.internal instead of localhost
# if your media server is on a different machine.

JELLYFIN_API_KEY=
JELLYFIN_URL=http://localhost:8096
PLEX_TOKEN=
PLEX_URL=http://localhost:32400
EMBY_API_KEY=
EMBY_URL=http://localhost:8096
ERSATZTV_URL=
